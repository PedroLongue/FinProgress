generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String   @id @default(uuid())
  name                         String
  email                        String   @unique
  password                     String
  isActive                     Boolean  @default(true) @map("is_active")
  createdAt                    DateTime @default(now()) @map("created_at")
  phone                        String?
  notificationsEnabled         Boolean  @default(false) @map("notifications_enabled")
  emailNotificationsEnabled    Boolean  @default(false) @map("email_notifications_enabled")
  telegramNotificationsEnabled Boolean  @default(false) @map("telegram_notifications_enabled")
  telegramChatId               String?  @map("telegram_chat_id")
  billReminderDays             Int      @default(2) @map("bill_reminder_days")

  bills                Bill[]
  monthlySpendingGoals MonthlySpendingGoal[]
  notifications        Notification[]

  @@map("users")
}

model Bill {
  id          String     @id @default(uuid())
  title       String
  amount      Float
  dueDate     DateTime   @map("due_date")
  category    String?
  status      BillStatus @default(PENDING) @map("status")
  createdAt   DateTime   @default(now()) @map("created_at")
  barcode     String?    @unique @map("barcode")
  description String?    @map("description")
  paidAt      DateTime?  @map("paid_at")
  userId      String     @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueDate])
  @@index([category])
  @@index([status])
  @@map("bills")
}

enum BillStatus {
  PENDING // Pendente
  PAID // Pago
  PAID_LATE // Pago com atraso
  OVERDUE // Vencido
}

model MonthlySpendingGoal {
  id        String   @id @default(uuid())
  userId    String
  month     DateTime
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
  @@map("monthly_spending_goals")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  billId    String?  @map("bill_id")
  dueDate   String?  @map("due_date")

  emailSent Boolean @default(false) @map("email_sent") // Indica se a notificação por email já foi enviada (evita envios duplicados)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, billId, dueDate])
  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
