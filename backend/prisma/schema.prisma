generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  phone     String?

  billReminderDays Int @default(2) @map("bill_reminder_days")

  bills                Bill[]
  monthlySpendingGoals MonthlySpendingGoal[]

  @@map("users")
}

model Bill {
  id          String     @id @default(uuid())
  title       String
  amount      Float
  dueDate     DateTime   @map("due_date")
  category    String?
  status      BillStatus @default(PENDING) @map("status")
  createdAt   DateTime   @default(now()) @map("created_at")
  barcode     String?    @unique @map("barcode")
  description String?    @map("description")
  paidAt      DateTime?  @map("paid_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueDate])
  @@index([category])
  @@index([status])
  @@map("bills")
}

enum BillStatus {
  PENDING // Pendente
  PAID // Pago
  PAID_LATE // Pago com atraso
  OVERDUE // Vencido
}

model MonthlySpendingGoal {
  id     String   @id @default(uuid())
  userId String
  month  DateTime
  amount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
  @@map("monthlyspendinggoal")
}
